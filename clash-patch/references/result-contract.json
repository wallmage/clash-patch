{
  "schema": "clash-patch.result",
  "version": 1,
  "required_fields": [
    "schema",
    "version",
    "command",
    "platform",
    "client",
    "operation",
    "ok",
    "status",
    "code",
    "exit_code",
    "summary_zh",
    "profile",
    "changes",
    "checks",
    "items",
    "messages",
    "warnings"
  ],
  "statuses": [
    "ok",
    "no_change",
    "skipped",
    "failed",
    "rolled_back",
    "partial",
    "invalid_request",
    "unsupported"
  ],
  "item_statuses": [
    "updated",
    "unchanged",
    "skipped",
    "failed",
    "rolled_back",
    "pending"
  ],
  "commands": [
    "install",
    "uninstall",
    "patch",
    "verify_routes"
  ],
  "field_types": {
    "schema": "string",
    "version": "integer",
    "command": "string",
    "platform": "string",
    "client": "string",
    "operation": "string",
    "ok": "boolean",
    "status": "string",
    "code": "string",
    "exit_code": "integer",
    "summary_zh": "string",
    "profile": ["integer", "null"],
    "changes": "array",
    "checks": "array",
    "items": "array",
    "messages": "array",
    "warnings": "array"
  },
  "platforms": {
    "macos": {
      "client": "clashx-meta",
      "json_argument": "--json"
    },
    "windows": {
      "client": "clash-verge-rev",
      "json_argument": "-Json"
    }
  }
}
