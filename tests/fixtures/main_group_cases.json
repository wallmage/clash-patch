        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "Streaming", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "节点选择", "type": "select", "proxies": ["台湾家宽 01"] }
