      "expected_main_group": "Provider-Fallback"
    },
    {
      "name": "reject-pass-compatible-and-lowercase-direct-groups-are-skipped",
      "config": {
        "proxies": [{ "name": "node", "type": "ss", "server": "node.example" }],
