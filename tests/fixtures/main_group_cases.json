{
  "schema_version": 1,
  "comment": "Shared macOS/Windows conformance cases. transform_cases lock the reviewed full output with expected_config_sha256, then require both engines to produce the same configuration without mutating the input; expected_main_group null means no valid main group exists.",
  "cases": [
    {
      "name": "match-target-wins",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "AI", "type": "select", "proxies": ["Main"] }
        ],
        "rules": ["GEOSITE,CN,DIRECT", "MATCH,Main"]
      },
      "expected_main_group": "Main"
    },
    {
      "name": "match-direct-broad-references-win",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "节点选择", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "AI", "type": "select", "proxies": ["节点选择"] }
        ],
        "rules": ["GEOSITE,GOOGLE,节点选择", "GEOIP,US,节点选择", "GEOSITE,CN,DIRECT", "MATCH,DIRECT"]
      },
      "expected_main_group": "节点选择"
    },
    {
      "name": "no-match-uses-common-name",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "Streaming", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "节点选择", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": ["GEOSITE,CN,DIRECT"]
      },
      "expected_main_group": "节点选择"
    },
    {
      "name": "fallback-skips-ai-and-direct-only-groups",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "DirectOnly", "type": "select", "proxies": ["DIRECT"] },
          { "name": "LastResort", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": []
      },
      "expected_main_group": "LastResort"
    },
    {
      "name": "ai-only-group-rejected",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": ["MATCH,AI"]
      },
      "expected_main_group": null
    },
    {
      "name": "no-valid-main-group",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "DirectOnly", "type": "select", "proxies": ["DIRECT"] }
        ],
        "rules": ["MATCH,DIRECT"]
      },
      "expected_main_group": null
    },
    {
      "name": "narrow-streaming-rules-do-not-outrank",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "Streaming", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "节点选择", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": [
          "DOMAIN-SUFFIX,youtube.com,Streaming",
          "DOMAIN-SUFFIX,googlevideo.com,Streaming",
          "DOMAIN-SUFFIX,netflix.com,Streaming",
          "DOMAIN-SUFFIX,nflxvideo.net,Streaming",
          "DOMAIN-SUFFIX,disneyplus.com,Streaming",
          "DOMAIN-KEYWORD,stream,Streaming",
          "GEOSITE,CN,DIRECT",
          "MATCH,DIRECT"
        ]
      },
      "expected_main_group": "节点选择"
    },
    {
      "name": "ai-broad-references-excluded",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "Final", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": ["GEOIP,US,AI", "GEOSITE,GOOGLE,AI", "MATCH,DIRECT"]
      },
      "expected_main_group": "Final"
    },
    {
      "name": "match-target-ai-falls-through",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "Proxy", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": ["MATCH,AI"]
      },
      "expected_main_group": "Proxy"
    },
    {
      "name": "single-broad-reference-not-enough",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "Special", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "Proxy", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": ["GEOIP,US,Special", "MATCH,DIRECT"]
      },
      "expected_main_group": "Proxy"
    },
    {
      "name": "broad-no-resolve-target-counted",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "节点选择", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "AI", "type": "select", "proxies": ["节点选择"] }
        ],
        "rules": ["GEOIP,US,节点选择,no-resolve", "GEOSITE,GOOGLE,节点选择", "MATCH,DIRECT"]
      },
      "expected_main_group": "节点选择"
    },
    {
      "name": "provider-only-selector-usable-as-fallback",
      "config": {
        "proxy-providers": { "provider1": { "type": "http", "url": "https://example.invalid/sub", "interval": 3600 } },
        "proxy-groups": [
          { "name": "AI", "type": "select", "use": ["provider1"] },
          { "name": "Provider-Fallback", "type": "select", "use": ["provider1"] }
        ],
        "rules": []
      },
      "expected_main_group": "Provider-Fallback"
    },
    {
      "name": "reject-pass-compatible-and-lowercase-direct-groups-are-skipped",
      "config": {
        "proxies": [{ "name": "node", "type": "ss", "server": "node.example" }],
        "proxy-groups": [
          { "name": "RejectOnly", "type": "select", "proxies": ["REJECT"] },
          { "name": "PassOnly", "type": "select", "proxies": ["pass"] },
          { "name": "CompatibleOnly", "type": "select", "proxies": ["compatible"] },
          { "name": "LowerDirectOnly", "type": "select", "proxies": ["direct"] },
          { "name": "Usable", "type": "select", "proxies": ["node"] }
        ],
        "rules": []
      },
      "expected_main_group": "Usable"
    },
    {
      "name": "arbitrary-rule-set-references-are-counted",
      "config": {
        "proxies": [{ "name": "node", "type": "ss", "server": "node.example" }],
        "proxy-groups": [
          { "name": "Custom", "type": "select", "proxies": ["node"] },
          { "name": "Proxy", "type": "select", "proxies": ["node"] }
        ],
        "rules": ["RULE-SET,gfw,Custom", "RULE-SET,geolocation-!cn,Custom", "MATCH,DIRECT"]
      },
      "expected_main_group": "Custom"
    },
    {
      "name": "broad-reference-tie-uses-group-order",
      "config": {
        "proxies": [{ "name": "node", "type": "ss", "server": "node.example" }],
        "proxy-groups": [
          { "name": "First", "type": "select", "proxies": ["node"] },
          { "name": "Second", "type": "select", "proxies": ["node"] }
        ],
        "rules": [
          "RULE-SET,one,Second", "RULE-SET,two,First",
          "GEOSITE,example,Second", "GEOIP,US,First", "MATCH,DIRECT"
        ]
      },
      "expected_main_group": "First"
    },
    {
      "name": "non-select-match-target-falls-through",
      "config": {
        "proxies": [{ "name": "node", "type": "ss", "server": "node.example" }],
        "proxy-groups": [
          { "name": "Auto", "type": "url-test", "proxies": ["node"], "url": "https://example.invalid" },
          { "name": "Proxy", "type": "select", "proxies": ["node"] }
        ],
        "rules": ["MATCH,Auto"]
      },
      "expected_main_group": "Proxy"
    },
    {
      "name": "missing-match-target-falls-through",
      "config": {
        "proxies": [{ "name": "node", "type": "ss", "server": "node.example" }],
        "proxy-groups": [
          { "name": "Proxy", "type": "select", "proxies": ["node"] },
          { "name": "Fallback", "type": "select", "proxies": ["node"] }
        ],
        "rules": ["MATCH,Missing"]
      },
      "expected_main_group": "Proxy"
    }
  ],
  "transform_cases": [
    {
      "name": "reuse-existing-ai-group",
      "expected_config_sha256": "7218fe4b0f93956248bd00bd49e297c23b4a3cd348fe07409e0e731f69102261",
      "input": {
        "proxies": [{ "name": "node-a", "type": "ss", "server": "node-a.example" }],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["node-a"] },
          { "name": "AI", "type": "select", "proxies": ["node-a"], "icon": "keep-me" }
        ],
        "rules": ["MATCH,Main"]
      },
      "expected_changed": true,
      "expected_main_group": "Main",
      "expected_ai_group": "AI",
      "expected_status": "updated"
    },
    {
      "name": "create-independent-ai-from-provider",
      "expected_config_sha256": "6c1060d1ad689b37ef5fda2bfd5fb5a7499f1ef93e598533c10cf33869df260e",
      "input": {
        "proxy-providers": {
          "provider-a": { "type": "http", "url": "https://fixture.invalid/sub", "interval": 3600 }
        },
        "proxy-groups": [
          { "name": "Main", "type": "select", "use": ["provider-a"] }
        ],
        "rules": ["MATCH,Main"]
      },
      "expected_changed": true,
      "expected_main_group": "Main",
      "expected_ai_group": "🤖 AI · Clash Patch",
      "expected_status": "updated"
    },
    {
      "name": "normalize-dns-and-managed-rule-whitespace",
      "expected_config_sha256": "64bafaaebd1a99435b6695c915e28795fcc4aeec68d0ca4de244ab92318113b7",
      "input": {
        "proxies": [{ "name": "node-a", "type": "ss", "server": "node-a.example" }],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["node-a"] },
          { "name": "AI", "type": "select", "proxies": ["node-a"] }
        ],
        "dns": {
          "nameserver": ["8.8.8.8"],
          "nameserver-policy": {
            "+.openai.com,+.example.org": ["udp://8.8.8.8#DIRECT"]
          }
        },
        "rules": [
          "DOMAIN-SUFFIX, openai.com, AI",
          "RULE-SET,global,Main",
          "MATCH,Main"
        ]
      },
      "expected_changed": true,
      "expected_main_group": "Main",
      "expected_ai_group": "AI",
      "expected_status": "updated"
    },
    {
      "name": "migrate-owned-legacy-groups",
      "expected_config_sha256": "e297c891c6928bd70866991288dbd976d89e649749b6e197400f1ac5b0998c89",
      "input": {
        "proxies": [{ "name": "node-a", "type": "ss", "server": "node-a.example" }],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["node-a"] },
          { "name": "🤖 AI · Clash Patch", "type": "select", "proxies": ["node-a"] },
          {
            "name": "🛡 安全代理 · Clash Patch",
            "type": "select",
            "proxies": ["node-a"],
            "include-all": true,
            "exclude-type": "Direct|Dns|Reject|Pass|Compatible|Rematch",
            "empty-fallback": "REJECT"
          }
        ],
        "dns": {
          "nameserver-policy": {
            "+.ai.com": ["https://dns.google/dns-query#🛡 安全代理 · Clash Patch"]
          }
        },
        "rules": [
          "NETWORK,UDP,🛡 安全代理 · Clash Patch",
          "NETWORK,UDP,REJECT",
          "DOMAIN-SUFFIX,openai.com,🤖 AI · Clash Patch",
          "IP-CIDR,160.79.104.0/21,🤖 AI · Clash Patch,no-resolve",
          "DOMAIN-SUFFIX,ai.com,🤖 AI · Clash Patch",
          "MATCH,Main"
        ]
      },
      "expected_changed": true,
      "expected_main_group": "Main",
      "expected_ai_group": "🤖 AI · Clash Patch",
      "expected_status": "updated",
      "expected_absent_strings": [
        "🛡 安全代理 · Clash Patch",
        "DOMAIN-SUFFIX,ai.com,🤖 AI · Clash Patch",
        "IP-CIDR,160.79.104.0/21,🤖 AI · Clash Patch,no-resolve",
        "+.ai.com"
      ],
      "expected_present_strings": [
        "IP-CIDR,160.79.104.0/23,🤖 AI · Clash Patch,no-resolve",
        "NETWORK,UDP,🤖 AI · Clash Patch"
      ]
    },
    {
      "name": "no-valid-main-group-stays-unchanged",
      "expected_config_sha256": "5ac8ffd66a8e932e5674aab3b1d78fd1e444e5aee7c865e5c387849d1befdc13",
      "input": {
        "proxies": [{ "name": "node-a", "type": "ss", "server": "node-a.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["node-a"] },
          { "name": "DirectOnly", "type": "select", "proxies": ["DIRECT"] }
        ],
        "rules": ["MATCH,DIRECT"]
      },
      "expected_changed": false,
      "expected_main_group": null,
      "expected_ai_group": null,
      "expected_status": "no_main_group"
    },
    {
      "name": "no-ai-sources-stays-unchanged",
      "expected_config_sha256": "38309b94746aef44c537c0a0f0eb05ff40235d725ad63f31b0a6247ae42119e0",
      "input": {
        "proxies": [],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["unresolved-node"] }
        ],
        "rules": ["MATCH,Main"]
      },
      "expected_changed": false,
      "expected_main_group": null,
      "expected_detected_main_group": "Main",
      "expected_ai_group": null,
      "expected_status": "no_ai_nodes"
    },
    {
      "name": "invalid-array-input-stays-unchanged",
      "expected_config_sha256": "4f53cda18c2baa0c0354bb5f9a3ecbe5ed12ab4d8e11ba873c2f11161202b945",
      "input": [],
      "expected_changed": false,
      "expected_main_group": null,
      "expected_ai_group": null,
      "expected_status": "invalid"
    }
  ]
}
