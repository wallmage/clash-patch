          }
        },
        "rules": [
          "NETWORK,UDP,🛡 安全代理 · Clash Patch",
          "NETWORK,UDP,REJECT",
          "DOMAIN-SUFFIX,openai.com,🤖 AI · Clash Patch",
          "IP-CIDR,160.79.104.0/21,🤖 AI · Clash Patch,no-resolve",
          "DOMAIN-SUFFIX,ai.com,🤖 AI · Clash Patch",
          "MATCH,Main"
        ]
      },
      "expected_changed": true,
      "expected_main_group": "Main",
      "expected_ai_group": "🤖 AI · Clash Patch",
      "expected_status": "updated",
      "expected_absent_strings": [
        "🛡 安全代理 · Clash Patch",
        "DOMAIN-SUFFIX,ai.com,🤖 AI · Clash Patch",
        "IP-CIDR,160.79.104.0/21,🤖 AI · Clash Patch,no-resolve",
        "+.ai.com"
      ],
      "expected_present_strings": [
        "IP-CIDR,160.79.104.0/23,🤖 AI · Clash Patch,no-resolve",
        "NETWORK,UDP,🤖 AI · Clash Patch"
      ]
    },
