  "transform_cases": [
    {
      "name": "automatic-main-group-receives-full-patch",
      "expected_config_sha256": "0aaeb2e1f4c26480f10ae857b739390087cf07d5e7cb6a19991c893b76f72665",
      "input": {
        "proxies": [{ "name": "node-a", "type": "ss", "server": "node-a.example" }],
        "proxy-groups": [
          { "name": "Auto", "type": "url-test", "proxies": ["node-a"], "url": "https://example.invalid", "interval": 300 }
        ],
        "rules": ["MATCH,Auto"]
      },
      "expected_changed": true,
      "expected_main_group": "Auto",
      "expected_ai_group": "🤖 AI · Clash Patch",
      "expected_status": "updated",
      "expected_present_strings": [
        "\"proxy\":\"Auto\"",
        "NETWORK,UDP,🤖 AI · Clash Patch"
      ]
    },
    {
      "name": "reuse-existing-ai-group",
      "expected_config_sha256": "c7de18d54d6e3476166c4246435fdc93a44875d17512ca201b342638c36a8691",
      "input": {
        "proxies": [{ "name": "node-a", "type": "ss", "server": "node-a.example" }],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["node-a"] },
          { "name": "AI", "type": "select", "proxies": ["node-a"], "icon": "keep-me" }
        ],
        "rules": ["MATCH,Main"]
      },
      "expected_changed": true,
      "expected_main_group": "Main",
      "expected_ai_group": "AI",
      "expected_status": "updated"
    },
