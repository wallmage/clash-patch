{
  "schema_version": 1,
  "comment": "Shared macOS/Windows conformance cases. transform_cases lock the reviewed full output with expected_config_sha256, then require both engines to produce the same configuration without mutating the input; all Mihomo proxy-group types are valid route-group candidates and AI-named or direct-only groups are last resorts.",
  "cases": [
    {
      "name": "match-target-wins",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "AI", "type": "select", "proxies": ["Main"] }
        ],
        "rules": ["GEOSITE,CN,DIRECT", "MATCH,Main"]
      },
      "expected_main_group": "Main"
    },
    {
      "name": "match-direct-broad-references-win",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "节点选择", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "AI", "type": "select", "proxies": ["节点选择"] }
        ],
        "rules": ["GEOSITE,GOOGLE,节点选择", "GEOIP,US,节点选择", "GEOSITE,CN,DIRECT", "MATCH,DIRECT"]
      },
      "expected_main_group": "节点选择"
    },
    {
      "name": "no-match-uses-common-name",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "Streaming", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "节点选择", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": ["GEOSITE,CN,DIRECT"]
      },
      "expected_main_group": "节点选择"
    },
    {
      "name": "fallback-skips-ai-and-direct-only-groups",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "DirectOnly", "type": "select", "proxies": ["DIRECT"] },
          { "name": "LastResort", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": []
      },
      "expected_main_group": "LastResort"
    },
    {
      "name": "ai-only-group-is-last-resort",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] }
        ],
        "rules": ["MATCH,AI"]
      },
      "expected_main_group": "AI"
    },
    {
      "name": "ai-group-outranks-direct-only-last-resort",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
        "proxy-groups": [
          { "name": "AI", "type": "select", "proxies": ["台湾家宽 01"] },
          { "name": "DirectOnly", "type": "select", "proxies": ["DIRECT"] }
        ],
        "rules": ["MATCH,DIRECT"]
      },
      "expected_main_group": "AI"
    },
    {
      "name": "direct-only-group-is-final-valid-fallback",
      "config": {
        "proxies": [{ "name": "台湾家宽 01", "type": "ss", "server": "tw.example" }],
