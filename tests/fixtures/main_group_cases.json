          }
        },
        "rules": [
          "DOMAIN-SUFFIX, openai.com, AI",
          "RULE-SET,global,Main",
          "MATCH,Main"
        ]
      },
      "expected_changed": true,
      "expected_main_group": "Main",
      "expected_ai_group": "AI",
      "expected_status": "updated"
    },
    {
      "name": "migrate-owned-legacy-groups",
      "expected_config_sha256": "ea04861d52417b7397285e2c7d88bcd274f54d57d5d395647b8a455efd33afe6",
      "input": {
        "proxies": [{ "name": "node-a", "type": "ss", "server": "node-a.example" }],
        "proxy-groups": [
          { "name": "Main", "type": "select", "proxies": ["node-a"] },
          { "name": "🤖 AI · Clash Patch", "type": "select", "proxies": ["node-a"] },
          {
            "name": "🛡 安全代理 · Clash Patch",
            "type": "select",
            "proxies": ["node-a"],
            "include-all": true,
            "exclude-type": "Direct|Dns|Reject|Pass|Compatible|Rematch",
